# ============================================================
# Pawchive Environment Variables
# Copy to .env.local for local development
# ============================================================

# ---- Supabase ----
# Get these from https://app.supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key (server-only, never commit or expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Site URL ----
# PAWCHIVE_SITE_URL=https://pawchive.dragonjay.top

# ---- Admin Credentials (fallback) ----
PAWCHIVE_ADMIN_USER=admin
PAWCHIVE_ADMIN_PASS=admin
PAWCHIVE_ADMIN_SECRET=pawchive-admin-dev-secret-change-me
