# ============================================================
# Pawchive Environment Variables
# Copy to .env.local for local development
# ============================================================

# Site URL (used for metadata / SEO canonical links)
# Defaults to http://localhost:3000 in dev
# PAWCHIVE_SITE_URL=https://pawchive.st

# ---- Admin Credentials (fallback) ----
# Used only when .data/admin.json does not exist.
# Once an admin signs in and changes credentials via Settings → Admin,
# values are scrypt-hashed into .data/admin.json.
PAWCHIVE_ADMIN_USER=admin
PAWCHIVE_ADMIN_PASS=admin

# ---- Admin Session Secret ----
# HMAC signing key for admin session cookies.
# In production you MUST set this to a long random string.
PAWCHIVE_ADMIN_SECRET=pawchive-admin-dev-secret-change-me
